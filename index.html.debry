<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bąbelkowy Ogród Finansowy PRO</title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<style>

html,body{
height:100%;
margin:0;
overflow:hidden;
font-family:sans-serif;
touch-action:pan-y;
}

body{
background:linear-gradient(135deg,#e0f2fe 0%,#f8fafc 50%,#f0fdf4 100%);
background-size:200% 200%;
animation:bgMove 12s ease infinite;
display:flex;
justify-content:center;
align-items:center;
padding:10px;
}

@keyframes bgMove{
0%{background-position:0% 50%;}
50%{background-position:100% 50%;}
100%{background-position:0% 50%;}
}

.app{
width:100%;
max-width:430px;
height:96vh;
background:rgba(255,255,255,.88);
backdrop-filter:blur(20px);
border-radius:38px;
overflow:hidden;
display:flex;
flex-direction:column;
box-shadow:0 25px 60px rgba(0,0,0,.12);
border:1px solid rgba(255,255,255,.7);
position:relative;
}

.scroll{
flex:1;
overflow-y:auto;
padding:16px;
-webkit-overflow-scrolling:touch;
}

.topbar{
background:linear-gradient(90deg,#22d3ee,#10b981);
padding:16px;
display:flex;
justify-content:space-between;
align-items:center;
color:white;
}

.title{
font-weight:900;
font-size:14px;
}

.balanceCard{
background:white;
border-radius:28px;
padding:20px;
border:2px solid #cffafe;
box-shadow:0 0 25px rgba(34,211,238,.18);
}

.goalCard{
background:white;
border-radius:28px;
padding:18px;
position:relative;
overflow:hidden;
border:1px solid #e2e8f0;
}

.wave{
position:absolute;
width:220%;
height:220%;
left:-60%;
border-radius:40%;
animation:waveRotate 10s linear infinite;
}

@keyframes waveRotate{
0%{transform:rotate(0deg);}
100%{transform:rotate(360deg);}
}

.bubble{
position:absolute;
border-radius:999px;
animation:bubbleUp linear infinite;
opacity:.8;
}

@keyframes bubbleUp{
0%{
transform:translateY(0) scale(.5);
opacity:0;
}
20%{
opacity:1;
}
100%{
transform:translateY(-170px) scale(1.5);
opacity:0;
}
}

.slot{
background:white;
border-radius:24px;
padding:14px;
height:180px;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
border:1px solid #e2e8f0;
transition:.2s;
}

.slot:active{
transform:scale(.97);
}

.modal{
position:absolute;
inset:0;
background:rgba(0,0,0,.4);
backdrop-filter:blur(5px);
display:none;
justify-content:center;
align-items:center;
padding:20px;
z-index:100;
}

.modalBox{
background:white;
width:100%;
border-radius:28px;
padding:20px;
max-height:90vh;
overflow-y:auto;
}

input,select{
width:100%;
padding:14px;
border-radius:16px;
border:1px solid #cbd5e1;
background:#f8fafc;
font-weight:700;
outline:none;
}

.mainBtn{
padding:14px;
border-radius:18px;
font-weight:900;
border:none;
cursor:pointer;
}

.histItem{
background:white;
border-radius:18px;
padding:12px;
display:flex;
justify-content:space-between;
align-items:center;
border:1px solid #e2e8f0;
}

</style>
</head>

<body>

<div class="app">

<!-- HEADER -->

<div class="topbar">

<div>
<div class="title">
🫧 BĄBELKOWY OGRÓD
</div>

<div style="font-size:10px;opacity:.9;">
Premium Financial Garden
</div>
</div>

<div style="display:flex;gap:8px;">

<button onclick="openHistory()"
style="background:rgba(255,255,255,.2);border:none;padding:10px 12px;border-radius:14px;color:white;font-weight:900;">
📊
</button>

<button onclick="resetApp()"
style="background:rgba(255,255,255,.2);border:none;padding:10px 12px;border-radius:14px;color:white;font-weight:900;">
♻️
</button>

</div>

</div>

<!-- SCROLL -->

<div class="scroll">

<!-- BALANCE -->

<div class="balanceCard">

<div style="font-size:10px;font-weight:900;color:#94a3b8;text-transform:uppercase;">
Wolne środki
</div>

<div style="font-size:42px;font-weight:900;margin-top:6px;">
<span id="balanceText">0.00</span> €
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:18px;">

<button onclick="openATM('deposit')"
class="mainBtn"
style="background:#10b981;color:white;">
💵 WPŁAĆ
</button>

<button onclick="openATM('withdraw')"
class="mainBtn"
style="background:#ef4444;color:white;">
💸 WYDAJ
</button>

</div>

</div>

<!-- WATER -->

<div style="background:linear-gradient(90deg,#dbeafe,#cffafe);padding:18px;border-radius:24px;border:1px solid #bfdbfe;display:flex;justify-content:space-between;align-items:center;margin-top:16px;">

<div>

<div style="font-size:11px;font-weight:900;color:#0369a1;">
💧 Woda ogrodowa
</div>

<div style="font-size:10px;color:#64748b;margin-top:2px;">
Podlewaj rośliny
</div>

</div>

<div style="font-size:32px;font-weight:900;color:#0284c7;">
<span id="waterText">0</span>
</div>

</div>

<!-- GOALS -->

<div style="margin-top:22px;display:flex;justify-content:space-between;align-items:center;">

<div style="font-size:12px;font-weight:900;color:#475569;text-transform:uppercase;">
Cele oszczędnościowe
</div>

<button onclick="openGoalModal()"
style="background:#cffafe;color:#0891b2;border:none;padding:10px 14px;border-radius:999px;font-size:11px;font-weight:900;">
+ NOWY
</button>

</div>

<div id="goalsWrap" style="margin-top:14px;display:flex;flex-direction:column;gap:16px;"></div>

<!-- GARDEN -->

<div style="margin-top:28px;font-size:12px;font-weight:900;color:#475569;text-transform:uppercase;">
🏡 Twój ogród
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px;" id="gardenWrap"></div>

</div>

<!-- ATM MODAL -->

<div class="modal" id="atmModal">

<div class="modalBox">

<div style="display:flex;justify-content:space-between;align-items:center;">

<div style="font-size:18px;font-weight:900;">
🏧 Operacja
</div>

<button onclick="closeATM()"
style="border:none;background:none;font-size:24px;">
✕
</button>

</div>

<div style="margin-top:18px;">

<input type="number" id="atmAmount" placeholder="Kwota €">

</div>

<div style="margin-top:14px;">

<input type="text" id="atmReason" placeholder="Powód / marzenie / jedzenie (opcjonalnie)">

</div>

<div style="margin-top:18px;display:grid;grid-template-columns:1fr 1fr;gap:10px;">

<button onclick="closeATM()"
class="mainBtn"
style="background:#e2e8f0;">
Anuluj
</button>

<button onclick="confirmATM()"
class="mainBtn"
style="background:#06b6d4;color:white;">
Zatwierdź
</button>

</div>

</div>

</div>

<!-- GOAL MODAL -->

<div class="modal" id="goalModal">

<div class="modalBox">

<div style="display:flex;justify-content:space-between;align-items:center;">

<div style="font-size:18px;font-weight:900;">
🎯 Nowy cel
</div>

<button onclick="closeGoalModal()"
style="border:none;background:none;font-size:24px;">
✕
</button>

</div>

<div style="margin-top:16px;">
<input type="text" id="goalName" placeholder="Np. Telefon">
</div>

<div style="margin-top:14px;">
<input type="number" id="goalTarget" placeholder="Kwota docelowa €">
</div>

<div style="margin-top:18px;">
<button onclick="createGoal()"
class="mainBtn"
style="background:#10b981;color:white;width:100%;">
Stwórz cel
</button>
</div>

</div>

</div>

<!-- HISTORY MODAL -->

<div class="modal" id="historyModal">

<div class="modalBox">

<div style="display:flex;justify-content:space-between;align-items:center;">

<div style="font-size:18px;font-weight:900;">
📊 Historia
</div>

<button onclick="closeHistory()"
style="border:none;background:none;font-size:24px;">
✕
</button>

</div>

<div id="historyWrap"
style="margin-top:16px;display:flex;flex-direction:column;gap:10px;"></div>

</div>

</div>

</div>

<script>

let atmMode="deposit";

let data={
balance:0,
water:0,
goals:[],
history:[],
garden:[
{planted:false},
{planted:false},
{planted:false},
{planted:false}
],
inventory:["🥕","🍅","🧅","🍎"]
};

function save(){
localStorage.setItem("bubbleGardenFull",JSON.stringify(data));
}

function load(){

const stored=localStorage.getItem("bubbleGardenFull");

if(stored){
data=JSON.parse(stored);
}else{
save();
}

}

function resetApp(){

localStorage.removeItem("bubbleGardenFull");

location.reload();

}

function updateUI(){

document.getElementById("balanceText").innerText=data.balance.toFixed(2);

document.getElementById("waterText").innerText=data.water;

renderGoals();

renderGarden();

renderHistory();

save();

}

function openATM(type){

atmMode=type;

document.getElementById("atmModal").style.display="flex";

}

function closeATM(){

document.getElementById("atmModal").style.display="none";

}

function confirmATM(){

const amount=parseFloat(document.getElementById("atmAmount").value);

const reason=document.getElementById("atmReason").value;

if(isNaN(amount)||amount<=0)return;

const now=new Date();

const date=now.toLocaleDateString()+" "+now.toLocaleTimeString();

if(atmMode==="deposit"){

data.balance+=amount;

data.history.unshift({
type:"deposit",
text:"💵 Wpłata",
amount:amount,
date:date
});

}else{

if(amount>data.balance){
alert("Brak pieniędzy");
return;
}

data.balance-=amount;

data.history.unshift({
type:"withdraw",
text:reason
?`💸 Wydano na ${reason}`
:"💸 Wypłata",
amount:amount,
date:date
});

}

document.getElementById("atmAmount").value="";
document.getElementById("atmReason").value="";

closeATM();

updateUI();

}

function openGoalModal(){

document.getElementById("goalModal").style.display="flex";

}

function closeGoalModal(){

document.getElementById("goalModal").style.display="none";

}

function createGoal(){

const name=document.getElementById("goalName").value;

const target=parseFloat(document.getElementById("goalTarget").value);

if(!name||isNaN(target)||target<=0)return;

data.goals.push({
id:Date.now(),
name:name,
target:target,
current:0
});

document.getElementById("goalName").value="";
document.getElementById("goalTarget").value="";

closeGoalModal();

updateUI();

}

function addToGoal(id){

const val=prompt("Ile € chcesz dodać?");

const amount=parseFloat(val);

if(isNaN(amount)||amount<=0)return;

if(amount>data.balance){
alert("Brak środków");
return;
}

const goal=data.goals.find(g=>g.id===id);

goal.current+=amount;

data.balance-=amount;

data.water+=Math.max(1,Math.floor(amount/5));

data.history.unshift({
type:"goal",
text:`🫧 Wpłacono na marzenie ${goal.name}`,
amount:amount,
date:new Date().toLocaleString()
});

updateUI();

}

function buyGoal(id){

const goal=data.goals.find(g=>g.id===id);

if(goal.current<goal.target){
alert("Za mało oszczędności");
return;
}

goal.current-=goal.target;

data.history.unshift({
type:"buy",
text:`🛍️ Kupiono marzenie ${goal.name}`,
amount:goal.target,
date:new Date().toLocaleString()
});

alert("Kupiono: "+goal.name);

updateUI();

}

function removeGoal(id){

data.goals=data.goals.filter(g=>g.id!==id);

updateUI();

}

function renderGoals(){

const wrap=document.getElementById("goalsWrap");

wrap.innerHTML="";

if(data.goals.length===0){

wrap.innerHTML=`
<div style="background:white;border-radius:24px;padding:30px;text-align:center;color:#94a3b8;border:1px dashed #cbd5e1;">
Brak celów
</div>
`;

return;

}

data.goals.forEach(goal=>{

const percent=Math.min(
Math.round((goal.current/goal.target)*100),
100
);

let bubblesHTML="";

for(let i=0;i<8;i++){

const colors=["#38bdf8","#22c55e","#f472b6","#facc15","#a78bfa"];

bubblesHTML+=`
<div class="bubble"
style="
width:${6+Math.random()*10}px;
height:${6+Math.random()*10}px;
left:${Math.random()*100}%;
bottom:-20px;
background:${colors[Math.floor(Math.random()*colors.length)]};
animation-duration:${3+Math.random()*3}s;
animation-delay:${Math.random()*2}s;
">
</div>
`;

}

const top=100-percent;

const done=percent>=100;

wrap.innerHTML+=`

<div class="goalCard">

<div style="font-weight:900;font-size:16px;text-align:center;">
${goal.name}
</div>

<div style="font-size:11px;color:#64748b;text-align:center;margin-top:4px;">
${goal.current.toFixed(0)} € z ${goal.target.toFixed(0)} €
</div>

<div style="
width:170px;
height:170px;
margin:16px auto;
border-radius:999px;
background:#f8fafc;
padding:6px;
position:relative;
overflow:hidden;
border:5px solid #67e8f9;
">

<div style="
width:100%;
height:100%;
border-radius:999px;
overflow:hidden;
position:relative;
background:white;
">

<div class="wave"
style="
top:${top}%;
background:linear-gradient(to bottom,
${done ? "#34d399" : "#38bdf8"},
${done ? "#10b981" : "#2563eb"});
">
</div>

${bubblesHTML}

<div style="
position:absolute;
inset:0;
display:flex;
justify-content:center;
align-items:center;
font-size:34px;
font-weight:900;
color:white;
z-index:5;
text-shadow:0 2px 8px rgba(0,0,0,.2);
">
${percent}%
</div>

</div>

</div>

<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;">

<button onclick="addToGoal(${goal.id})"
class="mainBtn"
style="background:#cffafe;color:#0891b2;font-size:11px;">
💧 Dodaj
</button>

<button onclick="buyGoal(${goal.id})"
class="mainBtn"
style="background:#10b981;color:white;font-size:11px;">
🛍️ Kup
</button>

<button onclick="removeGoal(${goal.id})"
class="mainBtn"
style="background:#fee2e2;color:#ef4444;font-size:11px;">
✕
</button>

</div>

</div>

`;

});

}

function renderGarden(){

const wrap=document.getElementById("gardenWrap");

wrap.innerHTML="";

data.garden.forEach((slot,index)=>{

if(!slot.planted){

wrap.innerHTML+=`

<div class="slot"
onclick="plantSeed(${index})">

<div style="font-size:52px;">
🟤
</div>

<div style="margin-top:10px;font-weight:900;font-size:12px;">
Pusta gleba
</div>

</div>

`;

}else{

wrap.innerHTML+=`

<div class="slot"
onclick="waterPlant(${index})">

<div style="font-size:52px;">
${slot.emoji}
</div>

<div style="margin-top:10px;font-weight:900;font-size:12px;">
${slot.name}
</div>

<div style="width:100%;height:10px;background:#e2e8f0;border-radius:999px;margin-top:10px;overflow:hidden;">

<div style="
width:${slot.progress}%;
height:100%;
background:#10b981;
">
</div>

</div>

<div style="font-size:11px;margin-top:6px;color:#64748b;">
${slot.progress}%
</div>

</div>

`;

}

});

}

function plantSeed(index){

if(data.inventory.length===0){
alert("Brak nasion");
return;
}

const emoji=data.inventory.shift();

let name="Roślina";

if(emoji==="🥕")name="Marchewka";
if(emoji==="🍅")name="Pomidor";
if(emoji==="🧅")name="Cebula";
if(emoji==="🍎")name="Jabłoń";

data.garden[index]={
planted:true,
emoji:emoji,
name:name,
progress:0
};

updateUI();

}

function waterPlant(index){

const slot=data.garden[index];

if(!slot.planted)return;

if(data.water<=0){
alert("Brak wody");
return;
}

data.water-=1;

slot.progress+=10;

if(slot.progress>=100){

slot.progress=100;

data.inventory.push("🥕");

setTimeout(()=>{

data.garden[index]={planted:false};

updateUI();

},500);

}

updateUI();

}

function openHistory(){

document.getElementById("historyModal").style.display="flex";

}

function closeHistory(){

document.getElementById("historyModal").style.display="none";

}

function renderHistory(){

const wrap=document.getElementById("historyWrap");

wrap.innerHTML="";

if(data.history.length===0){

wrap.innerHTML=`
<div style="text-align:center;color:#94a3b8;padding:20px;">
Brak historii
</div>
`;

return;

}

data.history.forEach(item=>{

wrap.innerHTML+=`

<div class="histItem">

<div>

<div style="font-weight:900;font-size:13px;">
${item.text}
</div>

<div style="font-size:10px;color:#64748b;margin-top:3px;">
${item.date}
</div>

</div>

<div style="
font-weight:900;
font-size:16px;
color:${item.type==="deposit"?"#10b981":"#ef4444"};
">
${item.type==="deposit"?"+":"-"}${item.amount.toFixed(2)} €
</div>

</div>

`;

});

}

load();

updateUI();

</script>

</body>
</html>
